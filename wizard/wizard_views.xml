<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Store reconcile wizard — the auditor's Scanned -> Reconciled action -->
    <record id="view_vivo_session_reconcile_wizard_form" model="ir.ui.view">
        <field name="name">vivo.count.session.reconcile.wizard.form</field>
        <field name="model">vivo.count.session.reconcile.wizard</field>
        <field name="arch" type="xml">
            <form string="Reconcile Store">
                <sheet>
                    <div class="oe_title">
                        <h2>Reconcile store <field name="session_name" readonly="1" class="oe_inline"/></h2>
                    </div>
                    <field name="currency_id" invisible="1"/>
                    <div class="alert alert-info" role="status">
                        Reconcile every scanned rack in one pass. The scanner has finished
                        counting; as the auditor you record the variance/review note below and
                        confirm. Racks the scanner never finished are <strong>left out and
                        flagged</strong>, not reconciled. You must be a different user than the
                        scanner.
                    </div>
                    <group>
                        <group>
                            <field name="sections_total"/>
                            <field name="sections_ready" string="To reconcile now"/>
                            <field name="sections_unfinished" string="Left out (unfinished)"/>
                        </group>
                        <group>
                            <field name="variance_value" widget="monetary"/>
                            <field name="unfinished_names" string="Unfinished racks"
                                   invisible="sections_unfinished == 0"/>
                        </group>
                    </group>
                    <div class="alert alert-warning" role="status" invisible="sections_unfinished == 0">
                        <strong><field name="sections_unfinished" class="oe_inline"/></strong>
                        rack(s) are not finished and will be LEFT OUT of this reconcile
                        (excluded, not counted): <field name="unfinished_names" class="oe_inline"/>.
                    </div>
                    <group>
                        <field name="review_note" required="1"
                               placeholder="Mandatory: what the counts show and why you are reconciling."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="Reconcile Store" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Approval preview wizard -->
    <record id="view_vivo_approval_wizard_form" model="ir.ui.view">
        <field name="name">vivo.count.approval.wizard.form</field>
        <field name="model">vivo.count.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Approve Count Session">
                <sheet>
                    <div class="oe_title">
                        <h2>Review and approve <field name="session_id" readonly="1" class="oe_inline"/></h2>
                    </div>
                    <group>
                        <group string="Scope">
                            <field name="location_id"/>
                            <field name="sections_reconciled"/>
                            <field name="sections_total"/>
                            <field name="sections_outstanding"/>
                        </group>
                        <group string="Variance">
                            <field name="variance_value" widget="monetary"/>
                            <field name="tolerance_band"/>
                            <field name="variance_line_count"/>
                            <field name="sections_with_variance"/>
                            <field name="unreasoned_line_count"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Pre-flight">
                        <field name="band_authority_ok" widget="boolean_toggle" readonly="1"/>
                        <field name="sod_ok" widget="boolean_toggle" readonly="1"/>
                    </group>
                    <div class="alert alert-danger" role="alert" invisible="not is_blocked">
                        <field name="blocker_messages" readonly="1" nolabel="1"/>
                    </div>
                    <field name="is_blocked" invisible="1"/>
                    <field name="state" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_confirm_approve" type="object" string="Confirm Approval" class="btn-primary" invisible="is_blocked"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Recount gate wizard — Finish Scanning when Physical Count != Scanned -->
    <record id="view_vivo_recount_gate_wizard_form" model="ir.ui.view">
        <field name="name">vivo.count.recount.gate.wizard.form</field>
        <field name="model">vivo.count.recount.gate.wizard</field>
        <field name="arch" type="xml">
            <form string="Rack Count Mismatch">
                <sheet>
                    <field name="section_id" invisible="1"/>
                    <div class="alert alert-danger" role="alert">
                        <strong>Counts do not match for rack
                            <field name="section_name" class="oe_inline" readonly="1"/>.</strong><br/>
                        The manual Physical Count and the Scanned Total disagree. Choose
                        whether to accept the discrepancy and submit the rack for review,
                        or reject it and recount from scratch.
                    </div>
                    <group>
                        <field name="physical_total_qty"/>
                        <field name="scan_total_qty"/>
                    </group>
                    <div class="alert alert-warning" role="status">
                        <strong>Reject &amp; Recount</strong> will DELETE all
                        <field name="line_count" class="oe_inline" readonly="1"/> scanned
                        line(s) on this rack (including any unknown-barcode lines) and send it
                        back to scanning for a full rescan. This cannot be undone.
                    </div>
                </sheet>
                <footer>
                    <button name="action_proceed" type="object"
                            string="Proceed — Accept Discrepancy" class="btn-primary"/>
                    <button name="action_reject" type="object"
                            string="Reject &amp; Recount" class="btn-danger"
                            confirm="This will DELETE all scanned lines on this rack and require a full rescan. This cannot be undone. Continue?"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Bounce sections wizard -->
    <record id="view_vivo_bounce_wizard_form" model="ir.ui.view">
        <field name="name">vivo.count.bounce.wizard.form</field>
        <field name="model">vivo.count.bounce.wizard</field>
        <field name="arch" type="xml">
            <form string="Bounce Sections for Re-count">
                <sheet>
                    <div class="oe_title">
                        <h2>Bounce sections back for re-count</h2>
                    </div>
                    <p>The selected sections will be reset to scanning and re-done from scratch. Other reconciled sections are untouched.</p>
                    <group>
                        <field name="session_id" readonly="1"/>
                        <field name="section_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="reason"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_bounce" type="object" string="Bounce" class="btn-warning"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
