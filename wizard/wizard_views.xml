<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Approval preview wizard -->
    <record id="view_vivo_approval_wizard_form" model="ir.ui.view">
        <field name="name">vivo.count.approval.wizard.form</field>
        <field name="model">vivo.count.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Approve Count Session">
                <sheet>
                    <div class="oe_title">
                        <h2>Review and approve <field name="session_id" readonly="1" class="oe_inline"/></h2>
                    </div>
                    <group>
                        <group string="Scope">
                            <field name="location_id"/>
                            <field name="sections_reconciled"/>
                            <field name="sections_total"/>
                            <field name="sections_outstanding"/>
                        </group>
                        <group string="Variance">
                            <field name="variance_value" widget="monetary"/>
                            <field name="tolerance_band"/>
                            <field name="variance_line_count"/>
                            <field name="sections_with_variance"/>
                            <field name="unreasoned_line_count"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Pre-flight">
                        <field name="band_authority_ok" widget="boolean_toggle" readonly="1"/>
                        <field name="sod_ok" widget="boolean_toggle" readonly="1"/>
                    </group>
                    <div class="alert alert-danger" role="alert" invisible="not is_blocked">
                        <field name="blocker_messages" readonly="1" nolabel="1"/>
                    </div>
                    <field name="is_blocked" invisible="1"/>
                    <field name="state" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_confirm_approve" type="object" string="Confirm Approval" class="btn-primary" invisible="is_blocked"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Section review-and-reconcile wizard -->
    <record id="view_vivo_section_review_wizard_form" model="ir.ui.view">
        <field name="name">vivo.count.section.review.wizard.form</field>
        <field name="model">vivo.count.section.review.wizard</field>
        <field name="arch" type="xml">
            <form string="Review &amp; Reconcile Section">
                <sheet>
                    <div class="oe_title">
                        <h2>Review &amp; reconcile <field name="section_name" readonly="1" class="oe_inline"/></h2>
                    </div>
                    <field name="is_mismatch" invisible="1"/>
                    <div class="alert alert-info" role="status" invisible="is_mismatch">
                        Scan total equals the physical count, so this section is ready to
                        reconcile. Every SKU is listed below — items counted on this rack
                        (with any +/- variance) and items in the system snapshot that were
                        <strong>not counted here</strong>. Give a variance reason (and a note
                        for 'Other') for every <em>counted</em> line that differs from the
                        system, then confirm. A "not counted here" line needs no reason —
                        it is pending on another rack — but you may leave a remark.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="not is_mismatch">
                        The scanner's total and the physical counter's headcount still
                        disagree after re-scanning. As the auditor, set the authoritative
                        physical count and record why — your figure wins and is logged
                        against your name.
                    </div>
                    <group>
                        <field name="scan_total_qty"/>
                        <field name="physical_total_qty" string="Physical counter's figure"/>
                        <field name="authoritative_qty" invisible="not is_mismatch"/>
                        <field name="force_reason" invisible="not is_mismatch" required="is_mismatch"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom" create="0" delete="0" default_order="line_status asc, product_id"
                              decoration-danger="line_status == 'counted' and difference &lt; 0"
                              decoration-success="line_status == 'counted' and difference &gt; 0"
                              decoration-muted="line_status == 'not_counted'">
                            <field name="product_id" readonly="1"/>
                            <field name="line_status" string="Status" readonly="1"/>
                            <field name="system_qty" string="System" readonly="1"/>
                            <field name="counted_qty" string="Counted" readonly="1"/>
                            <field name="difference" string="Variance" readonly="1"/>
                            <field name="variance_reason" required="line_status == 'counted' and difference != 0"/>
                            <field name="variance_note" string="Remark"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm Reconciliation" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Bounce sections wizard -->
    <record id="view_vivo_bounce_wizard_form" model="ir.ui.view">
        <field name="name">vivo.count.bounce.wizard.form</field>
        <field name="model">vivo.count.bounce.wizard</field>
        <field name="arch" type="xml">
            <form string="Bounce Sections for Re-count">
                <sheet>
                    <div class="oe_title">
                        <h2>Bounce sections back for re-count</h2>
                    </div>
                    <p>The selected sections will be reset to scanning and re-done from scratch. Other reconciled sections are untouched.</p>
                    <group>
                        <field name="session_id" readonly="1"/>
                        <field name="section_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="reason"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_bounce" type="object" string="Bounce" class="btn-warning"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
