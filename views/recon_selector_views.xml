<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Stocktake picker: a Kanban of count sessions, each = one stocktake,
         from which the user opens that stocktake's recon report. The card's
         primary button reuses the session's existing action_open_recon_report
         (no report logic duplicated). -->
    <record id="view_vivo_recon_selector_kanban" model="ir.ui.view">
        <field name="name">vivo.count.session.recon.selector.kanban</field>
        <field name="model">vivo.count.session</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" sample="1" create="false"
                    default_order="scheduled_date desc">
                <field name="name"/>
                <field name="location_id"/>
                <field name="state"/>
                <field name="scheduled_date"/>
                <field name="sections_reconciled"/>
                <field name="sections_total"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card_content">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <span class="float-end badge rounded-pill text-bg-secondary">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="text-muted"><i class="fa fa-map-marker" title="Store" aria-label="Store" role="img"/> <field name="location_id"/></div>
                            <div class="text-muted small"><i class="fa fa-calendar" title="Date" aria-label="Date" role="img"/> <field name="scheduled_date"/></div>
                            <div class="mt-1 small">
                                <field name="sections_reconciled"/>/<field name="sections_total"/> racks reconciled
                            </div>
                            <div class="mt-2">
                                <button name="action_open_recon_report" type="object"
                                        class="btn btn-primary btn-sm">
                                    Open Recon Report
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Selector search: filter by state / store / date; group by store, state.
         No restrictive default filter — every stocktake shows. -->
    <record id="view_vivo_recon_selector_search" model="ir.ui.view">
        <field name="name">vivo.count.session.recon.selector.search</field>
        <field name="model">vivo.count.session</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="location_id"/>
                <filter name="filter_awaiting_reconcile" string="Awaiting Reconcile"
                        domain="[('state', 'in', ['in_progress', 'counted', 'review'])]"/>
                <filter name="filter_reconciled" string="Reconciled"
                        domain="[('state', 'in', ['approved', 'applied'])]"/>
                <separator/>
                <filter name="filter_this_week" string="Scheduled This Week" date="scheduled_date"/>
                <group string="Group By">
                    <filter name="group_location" string="Store" context="{'group_by': 'location_id'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_scheduled" string="Scheduled Date" context="{'group_by': 'scheduled_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- New front door for "Recon Report": the stocktake picker. Reuses the
         existing session list/form for the list/form view modes. -->
    <record id="action_vivo_recon_report_selector" model="ir.actions.act_window">
        <field name="name">Recon Report</field>
        <field name="res_model">vivo.count.session</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_vivo_recon_selector_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_vivo_recon_selector_kanban')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_vivo_count_session_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_vivo_count_session_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">No stocktakes yet.</p>
            <p>Pick a stocktake to open its merged recon report.</p>
        </field>
    </record>

</odoo>
