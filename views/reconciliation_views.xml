<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vivo_reconciliation_list" model="ir.ui.view">
        <field name="name">vivo.count.reconciliation.list</field>
        <field name="model">vivo.count.reconciliation</field>
        <field name="arch" type="xml">
            <list string="Stock Take Reconciliations" create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="session_id"/>
                <field name="location_id"/>
                <field name="generated_at"/>
                <field name="total_variance_value"/>
                <field name="variance_band"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_vivo_reconciliation_form" model="ir.ui.view">
        <field name="name">vivo.count.reconciliation.form</field>
        <field name="model">vivo.count.reconciliation</field>
        <field name="arch" type="xml">
            <form string="Stock Take Reconciliation" create="0" edit="0" delete="0">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="session_id"/>
                            <field name="location_id"/>
                            <field name="generated_at"/>
                            <field name="variance_band"/>
                        </group>
                        <group>
                            <field name="total_variance_qty"/>
                            <field name="total_variance_value"/>
                            <field name="overage_value"/>
                            <field name="shortage_value"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Participants">
                        <field name="scanner_ids" widget="many2many_tags"/>
                        <field name="physical_counter_ids" widget="many2many_tags"/>
                        <field name="reviewer_id"/>
                        <field name="approver_id"/>
                        <field name="applied_by_id"/>
                    </group>
                    <notebook>
                        <page string="Variance Lines">
                            <field name="line_ids">
                                <list decoration-danger="variance_type == 'shortage'" decoration-success="variance_type == 'overage'" create="0" edit="0" delete="0">
                                    <field name="zone_id"/>
                                    <field name="section_id"/>
                                    <field name="product_id"/>
                                    <field name="barcode"/>
                                    <field name="qty_before"/>
                                    <field name="qty_after"/>
                                    <field name="qty_variance"/>
                                    <field name="value_before"/>
                                    <field name="value_after"/>
                                    <field name="value_variance"/>
                                    <field name="variance_type"/>
                                    <field name="variance_reason"/>
                                    <field name="section_rescan_count"/>
                                    <field name="has_variance" column_invisible="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_vivo_reconciliation" model="ir.actions.act_window">
        <field name="name">Reconciliations</field>
        <field name="res_model">vivo.count.reconciliation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
