<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vivo_count_line_list" model="ir.ui.view">
        <field name="name">vivo.count.line.list</field>
        <field name="model">vivo.count.line</field>
        <field name="arch" type="xml">
            <list string="Count Lines">
                <field name="session_id"/>
                <field name="section_id"/>
                <field name="product_id"/>
                <field name="system_qty"/>
                <field name="counted_qty"/>
                <field name="difference"/>
                <field name="variance_value"/>
                <field name="variance_reason"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_vivo_count_line" model="ir.actions.act_window">
        <field name="name">Count Lines</field>
        <field name="res_model">vivo.count.line</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
