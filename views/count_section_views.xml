<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search: state, scanner, zone, locked, my work -->
    <record id="view_vivo_count_section_search" model="ir.ui.view">
        <field name="name">vivo.count.section.search</field>
        <field name="model">vivo.count.section</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="session_id"/>
                <field name="zone_id"/>
                <field name="scanner_id"/>
                <field name="physical_counter_id"/>
                <filter name="state_draft" string="Not Started" domain="[('state','=','draft')]"/>
                <filter name="state_scanning" string="Scanning" domain="[('state','=','scanning')]"/>
                <filter name="state_pending" string="Awaiting Store Reconcile" domain="[('state','=','pending_review')]"/>
                <filter name="state_reconciled" string="Reconciled" domain="[('state','=','reconciled')]"/>
                <filter name="state_excluded" string="Left Out" domain="[('state','=','excluded')]"/>
                <separator/>
                <filter name="filter_mine" string="My Sections" domain="['|',('scanner_id','=',uid),('physical_counter_id','=',uid)]"/>
                <filter name="filter_locked" string="In Progress (Locked)" domain="[('locked_by_id','!=',False)]"/>
                <filter name="filter_rescanned" string="Has Re-scans" domain="[('rescan_count','&gt;',0)]"/>
                <group string="Group By">
                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_zone" string="Zone" context="{'group_by':'zone_id'}"/>
                    <filter name="group_session" string="Session" context="{'group_by':'session_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- COLOUR-CODED SECTION PROGRESS BOARD — Phase 2 headline.

         grey = draft / excluded, amber = scanning,
         blue = pending_review (awaiting store reconcile), green = reconciled.
         Tile background is set via CSS class state-<state>. -->
    <record id="view_vivo_count_section_kanban" model="ir.ui.view">
        <field name="name">vivo.count.section.kanban</field>
        <field name="model">vivo.count.section</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_dashboard o_vivo_section_board" sample="1" group_create="0">
                <field name="state"/>
                <field name="name"/>
                <field name="zone_id"/>
                <field name="session_id"/>
                <field name="scanner_id"/>
                <field name="physical_counter_id"/>
                <field name="scan_total_qty"/>
                <field name="physical_total_qty"/>
                <field name="rescan_count"/>
                <field name="locked_by_id"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="o_vivo_section_tile state_#{record.state.raw_value}">
                            <div class="o_vivo_section_header">
                                <strong><field name="name"/></strong>
                                <span class="float-end" t-if="record.rescan_count.raw_value > 0">
                                    <i class="fa fa-refresh" title="Re-scan loops"/> <field name="rescan_count"/>
                                </span>
                            </div>
                            <div class="text-muted small"><field name="zone_id"/></div>
                            <div class="mt-2">
                                <div t-if="record.scanner_id.raw_value">
                                    <i class="fa fa-barcode"/> <field name="scanner_id"/>
                                </div>
                                <div t-if="record.physical_counter_id.raw_value">
                                    <i class="fa fa-hand-paper-o"/> <field name="physical_counter_id"/>
                                </div>
                                <div t-if="record.locked_by_id.raw_value and !record.scanner_id.raw_value" class="text-warning">
                                    <i class="fa fa-lock"/> In progress — <field name="locked_by_id"/>
                                </div>
                            </div>
                            <div class="mt-2 d-flex justify-content-between">
                                <span>Scan: <strong><field name="scan_total_qty"/></strong></span>
                                <span>Phys: <strong><field name="physical_total_qty"/></strong></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List view (unchanged from Phase 1, kept for managers wanting tabular) -->
    <record id="view_vivo_count_section_list" model="ir.ui.view">
        <field name="name">vivo.count.section.list</field>
        <field name="model">vivo.count.section</field>
        <field name="arch" type="xml">
            <list string="Sections" decoration-success="state == 'reconciled'" decoration-warning="state == 'scanning'" decoration-info="state == 'pending_review'" decoration-muted="state in ('draft','excluded')">
                <field name="session_id"/>
                <field name="zone_id"/>
                <field name="name"/>
                <field name="scanner_id"/>
                <field name="physical_counter_id"/>
                <field name="locked_by_id" optional="show"/>
                <field name="scan_total_qty"/>
                <field name="physical_total_qty"/>
                <field name="rescan_count"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_vivo_count_section_form" model="ir.ui.view">
        <field name="name">vivo.count.section.form</field>
        <field name="model">vivo.count.section</field>
        <field name="arch" type="xml">
            <form string="Section">
                <header>
                    <button name="action_start_scanning" type="object" string="Start Scanning" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_finish_scanning_gate" type="object" string="Finish Scanning" class="btn-primary" invisible="state != 'scanning'"/>
                    <button name="action_submit_physical_review" type="object" string="Submit Physical Count" class="btn-primary" invisible="state != 'pending_review'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,scanning,pending_review,reconciled"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="status" invisible="state in ('reconciled','excluded')">
                        Workflow: <strong>Draft → Scanning → Scanned (awaiting store reconcile) → Reconciled</strong>.
                        The scanner scans and clicks <strong>Finish Scanning</strong>, which
                        leaves the rack <strong>Scanned — Awaiting Store Reconcile</strong>.
                        There is <strong>no separate approver</strong>: a
                        <strong>different auditor</strong> then reviews and reconciles the
                        <strong>whole store in one pass</strong> from the session
                        (<strong>Reconcile Store</strong>) and posts it to stock. A rack still
                        unfinished when the store is reconciled is
                        <strong>Left Out — Not Counted</strong>.
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="session_id"/>
                            <field name="zone_id"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="scanner_id"/>
                            <field name="physical_counter_id"/>
                            <field name="scan_total_qty"/>
                            <field name="physical_total_qty"/>
                            <field name="rescan_count"/>
                            <field name="reconciled_at"/>
                            <field name="reconciled_by_id"/>
                            <field name="review_note" invisible="not review_note"/>
                            <field name="force_reconciled" invisible="not force_reconciled"/>
                            <field name="force_reconcile_reason" invisible="not force_reconciled"/>
                            <field name="locked_by_id"/>
                            <field name="locked_at"/>
                        </group>
                    </group>
                    <div class="alert alert-danger" role="status" invisible="not recount_log">
                        <strong>Recount history</strong>
                        <field name="recount_log" readonly="1" nolabel="1"/>
                    </div>
                    <notebook>
                        <page string="Counted in this rack" name="counted">
                            <field name="counted_line_count" invisible="1"/>
                            <field name="line_ids" domain="[('counted_qty', '&gt;', 0)]" context="{'default_section_id': id}">
                                <list editable="bottom" decoration-danger="is_unknown or difference &lt; 0" decoration-success="not is_unknown and difference &gt; 0">
                                    <field name="is_unknown" column_invisible="1"/>
                                    <field name="product_id"/>
                                    <field name="barcode" readonly="1"/>
                                    <field name="scanned_barcode" string="Unknown Barcode" optional="show"/>
                                    <field name="system_qty"/>
                                    <field name="counted_qty"/>
                                    <field name="unit_cost" string="Cost" readonly="1"/>
                                    <field name="lst_price" readonly="1"/>
                                    <field name="difference"/>
                                    <field name="total_retail_price" string="Total Retail Price" readonly="1"/>
                                    <field name="variance_reason"/>
                                    <field name="variance_note"/>
                                    <field name="no_barcode_flag"/>
                                    <field name="line_status" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Not counted here" name="not_counted">
                            <field name="not_counted_line_count" invisible="1"/>
                            <div class="alert alert-secondary" role="status">
                                These SKUs are loaded from the system snapshot but were
                                not scanned on this rack. They are treated as
                                <strong>pending on other racks — not variances</strong> —
                                and need no variance reason here. An SKU left uncounted on
                                <em>every</em> rack of the session is flagged as a genuine
                                shortage on the session.
                            </div>
                            <field name="not_counted_line_ids" readonly="1">
                                <list>
                                    <field name="product_id"/>
                                    <field name="barcode"/>
                                    <field name="system_qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vivo_count_section" model="ir.actions.act_window">
        <field name="name">Sections</field>
        <field name="res_model">vivo.count.section</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_vivo_count_section_search"/>
    </record>
</odoo>
