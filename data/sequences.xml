<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_vivo_count_session" model="ir.sequence">
            <field name="name">Vivo Count Session</field>
            <field name="code">vivo.count.session</field>
            <field name="prefix">VFG/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
        </record>
        <record id="seq_vivo_count_reconciliation" model="ir.sequence">
            <field name="name">Vivo Stock Take Reconciliation</field>
            <field name="code">vivo.count.reconciliation</field>
            <field name="prefix">RECON/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
        </record>
    </data>
</odoo>
